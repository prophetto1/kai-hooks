{
  "version": 1,
  "description": "Deterministic completion-gate manifest. The Stop hook maps git status to declared domains and runs these commands; exit codes are the only authority.",
  "repos": [
    {
      "name": "writing-system",
      "root": "E:/writing-system",
      "blockOnUnmatched": false,
      "domains": {
        "contracts": {
          "paths": [
            {
              "prefixes": [
                "contracts/",
                "governance/"
              ]
            },
            {
              "contains": [
                "/contract"
              ]
            },
            {
              "prefixes": [
                "scripts/tests/"
              ]
            }
          ],
          "commands": [
            {
              "label": "writing-system contract CI",
              "command": "pnpm run ci:contracts",
              "timeoutMs": 120000,
              "id": "writing-system-contract-ci",
              "classes": [
                "config",
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "frontend": {
          "paths": [
            {
              "prefixes": [
                "web/"
              ]
            },
            {
              "extensions": [
                ".tsx",
                ".jsx",
                ".css"
              ],
              "segments": [
                "web",
                "src"
              ]
            }
          ],
          "commands": [
            {
              "label": "writing-system frontend build",
              "command": "pnpm run ci:frontend",
              "timeoutMs": 120000,
              "id": "writing-system-frontend-build",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "writing-system web tests",
              "command": "pnpm run ci:web",
              "timeoutMs": 120000,
              "id": "writing-system-web-tests",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "devdocs": {
          "paths": [
            {
              "prefixes": [
                "apps/devdocs/"
              ]
            }
          ],
          "commands": [
            {
              "label": "writing-system devdocs build",
              "command": "pnpm run ci:devdocs",
              "timeoutMs": 120000,
              "id": "writing-system-devdocs-build",
              "classes": [
                "docs",
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "backend": {
          "paths": [
            {
              "prefixes": [
                "services/platform-api/"
              ]
            }
          ],
          "commands": [
            {
              "label": "writing-system platform-api tests",
              "command": "pnpm run ci:platform-api",
              "timeoutMs": 180000,
              "id": "writing-system-platform-api-tests",
              "classes": [
                "full-suite",
                "quality"
              ]
            }
          ]
        },
        "database": {
          "paths": [
            {
              "prefixes": [
                "supabase/migrations/"
              ]
            }
          ],
          "commands": [
            {
              "label": "writing-system supabase migration guardrails",
              "command": "pnpm run test:supabase-migration-guardrails",
              "timeoutMs": 120000,
              "id": "writing-system-supabase-migration-guardrails",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "secrets": {
          "paths": [
            {
              "prefixes": [
                "secrets/",
                "tools/secrets/"
              ]
            }
          ],
          "commands": [
            {
              "label": "writing-system plaintext secret scan",
              "command": "pnpm run secrets:check",
              "timeoutMs": 120000,
              "id": "writing-system-plaintext-secret-scan",
              "classes": [
                "security",
                "quality",
                "targeted"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "blockdata",
      "root": "E:/blockdata",
      "blockOnUnmatched": false,
      "domains": {
        "governance": {
          "paths": [
            {
              "prefixes": [
                "governance/"
              ]
            }
          ],
          "commands": [
            {
              "label": "blockdata contracts",
              "command": "node governance/scripts/check-contracts.mjs",
              "timeoutMs": 60000,
              "id": "blockdata-contracts",
              "classes": [
                "config",
                "quality",
                "targeted"
              ]
            },
            {
              "label": "blockdata npm deps",
              "command": "node governance/scripts/check-deps.mjs",
              "timeoutMs": 60000,
              "id": "blockdata-npm-deps",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "blockdata python deps",
              "command": "python governance/scripts/check-python-deps.py",
              "timeoutMs": 60000,
              "id": "blockdata-python-deps",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "backend": {
          "paths": [
            {
              "prefixes": [
                "services/api/"
              ]
            }
          ],
          "commands": [
            {
              "label": "blockdata python deps",
              "command": "python governance/scripts/check-python-deps.py",
              "timeoutMs": 60000,
              "id": "blockdata-python-deps-2",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "blockdata openapi",
              "command": "node governance/scripts/check-openapi.mjs",
              "timeoutMs": 60000,
              "id": "blockdata-openapi",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "devdocs": {
          "paths": [
            {
              "prefixes": [
                "apps/devdocs/"
              ]
            }
          ],
          "commands": [
            {
              "label": "blockdata devdocs build",
              "command": "pnpm --dir apps/devdocs run build",
              "timeoutMs": 180000,
              "id": "blockdata-devdocs-build",
              "classes": [
                "docs",
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "web": {
          "paths": [
            {
              "prefixes": [
                "apps/web/"
              ]
            }
          ],
          "commands": [
            {
              "label": "blockdata npm deps",
              "command": "node governance/scripts/check-deps.mjs",
              "timeoutMs": 60000,
              "id": "blockdata-npm-deps-2",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "kai-chattr",
      "root": "E:/kai-chattr",
      "blockOnUnmatched": false,
      "domains": {
        "web": {
          "paths": [
            {
              "prefixes": [
                "apps/web/"
              ]
            },
            {
              "prefixes": [
                "tests/e2e/"
              ]
            },
            {
              "prefixes": [
                ".cursor/"
              ]
            }
          ],
          "commands": [
            {
              "label": "kai-chattr playwright settings e2e",
              "id": "settings-e2e",
              "classes": [
                "browser",
                "targeted"
              ],
              "command": "npx playwright test tests/e2e/settings-page.spec.ts",
              "timeoutMs": 120000,
              "maxBuffer": 4194304
            },
            {
              "label": "kai-chattr playwright ui snapshot (live API)",
              "id": "live-ui-snapshot",
              "classes": [
                "browser"
              ],
              "command": "node scripts/dev/ui-snapshot-live.mjs",
              "timeoutMs": 120000,
              "maxBuffer": 4194304
            }
          ]
        },
        "api": {
          "paths": [
            {
              "prefixes": [
                "services/api/"
              ]
            }
          ],
          "commands": [
            {
              "label": "kai-chattr api tests",
              "id": "api-all-tests",
              "classes": [
                "quality",
                "full-suite"
              ],
              "command": "uv run python -m pytest tests/ -q",
              "cwd": "services/api",
              "env": {
                "UV_PROJECT_ENVIRONMENT": "%LOCALAPPDATA%\\uv\\envs\\kai-chattr-services-api"
              },
              "timeoutMs": 180000,
              "maxBuffer": 4194304
            }
          ]
        }
      }
    },
    {
      "name": "kai-agent",
      "root": "E:/kai-agent",
      "blockOnUnmatched": true,
      "domains": {
        "repo": {
          "paths": [
            {
              "prefixes": [
                ".github/",
                "_sources/",
                "docs/",
                "governance/",
                "scripts/",
                "src/",
                "tests/"
              ],
              "excludeSegments": [
                "__pycache__"
              ]
            },
            {
              "fileNames": [
                ".gitignore",
                "0618.txt",
                "AGENTS.md",
                "LICENSE",
                "README.md",
                "THIRD_PARTY_NOTICES.md",
                "changelog.md",
                "pyproject.toml"
              ]
            }
          ],
          "commands": [
            {
              "label": "kai-agent architecture guard",
              "command": "python scripts/check_architecture.py",
              "timeoutMs": 120000,
              "maxBuffer": 4194304,
              "id": "kai-agent-architecture-guard",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "kai-agent unit tests",
              "command": "python -m unittest discover -s tests",
              "timeoutMs": 120000,
              "maxBuffer": 4194304,
              "id": "kai-agent-unit-tests",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "kai-agent compile",
              "command": "python -m compileall -q src scripts tests",
              "timeoutMs": 120000,
              "maxBuffer": 4194304,
              "id": "kai-agent-compile",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "kai-agent diff whitespace",
              "command": "git diff --check",
              "timeoutMs": 30000,
              "maxBuffer": 4194304,
              "id": "kai-agent-diff-whitespace",
              "classes": [
                "targeted",
                "quality"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "chattr",
      "root": "E:/chattr",
      "blockOnUnmatched": false,
      "domains": {
        "backend": {
          "paths": [
            {
              "extensions": [
                ".py"
              ],
              "excludeSegments": [
                "__pycache__",
                ".venv"
              ]
            },
            {
              "prefixes": [
                "server/",
                "tests/",
                "schemas/",
                "scripts/",
                "windows/",
                "macos-linux/",
                "session_templates/"
              ]
            },
            {
              "fileNames": [
                "pyproject.toml",
                "uv.lock",
                "requirements.txt",
                "config.toml",
                "config.local.toml.example"
              ]
            }
          ],
          "commands": [
            {
              "label": "chattr backend tests",
              "command": "uv run pytest",
              "timeoutMs": 180000,
              "maxBuffer": 4194304,
              "id": "chattr-backend-tests",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        },
        "web": {
          "paths": [
            {
              "prefixes": [
                "apps/web/"
              ]
            },
            {
              "fileNames": [
                "package.json",
                "pnpm-lock.yaml",
                "pnpm-workspace.yaml"
              ]
            }
          ],
          "commands": [
            {
              "label": "chattr web build",
              "command": "pnpm --filter @chattr/web build",
              "timeoutMs": 180000,
              "maxBuffer": 4194304,
              "id": "chattr-web-build",
              "classes": [
                "quality",
                "targeted"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "skill-perfectionists",
      "root": "E:/skill-perfectionists",
      "blockOnUnmatched": true,
      "domains": {
        "repo": {
          "paths": [
            {
              "prefixes": [
                ""
              ],
              "excludeSegments": [
                ".git",
                "docs"
              ]
            }
          ],
          "commands": [
            {
              "label": "skill-perfectionists diff whitespace",
              "command": "git diff --check",
              "timeoutMs": 30000,
              "maxBuffer": 4194304,
              "id": "skill-perfectionists-diff-whitespace",
              "classes": [
                "targeted",
                "quality"
              ]
            }
          ]
        }
      }
    },
    {
      "name": "carops",
      "root": "E:/carops",
      "blockOnUnmatched": true,
      "domains": {
        "repo": {
          "paths": [
            {
              "prefixes": [
                ""
              ],
              "excludeSegments": [
                ".git",
                "node_modules",
                "references",
                "logs",
                "playwright-report",
                "test-results",
                "blob-report"
              ]
            }
          ],
          "commands": [
            {
              "label": "carops config contract",
              "id": "config-contract",
              "classes": [
                "quality",
                "config",
                "targeted"
              ],
              "command": "pnpm run check:config",
              "timeoutMs": 120000,
              "maxBuffer": 4194304
            }
          ]
        }
      }
    },
    {
      "name": "dbase",
      "root": "E:/dbase",
      "disabledReason": "Local Stop-gate checks would be bun-based, but this machine's global bun shim is broken ('The system cannot find the path specified'). dbase is authoritatively gated by its own .github/workflows/deploy-dev.yml CI (check:api-validation:strict, check:boundaries, check:realtime-prune, realtime type-check). Re-enable with an absolute bun.exe path once the shim is fixed and the rebrand sweep has landed.",
      "blockOnUnmatched": false,
      "domains": {}
    },
    {
      "name": "jwc-global",
      "root": "E:/jwc-global",
      "disabledReason": "Temporarily disabled while hook control-plane refactor is in progress.",
      "blockOnUnmatched": false,
      "domains": {}
    },
    {
      "name": "tfo",
      "root": "E:/tfo",
      "blockOnUnmatched": false,
      "domains": {
        "docs": {
          "paths": [
            {
              "extensions": [
                ".md",
                ".txt"
              ],
              "excludeSegments": [
                "v0.1",
                "archive",
                "references"
              ]
            },
            {
              "fileNames": [
                "AGENTS.md",
                "CHANGELOG.md",
                "DESIGN.md",
                "LICENSE",
                "README.md",
                "STACK.md"
              ]
            }
          ],
          "commands": [
            {
              "label": "tfo diff whitespace",
              "command": "git diff --check",
              "timeoutMs": 30000,
              "maxBuffer": 4194304,
              "id": "tfo-diff-whitespace",
              "classes": [
                "targeted",
                "quality"
              ]
            }
          ]
        },
        "prototype": {
          "paths": [
            {
              "prefixes": [
                "v0.1/src/",
                "v0.1/tests/",
                "v0.1/scripts/",
                "v0.1/proto/",
                "v0.1/hooks/",
                "v0.1/adapter-node/src/"
              ],
              "excludeSegments": [
                "__pycache__",
                ".venv",
                "node_modules",
                "data"
              ]
            },
            {
              "prefixes": [
                "v0.1/docs/",
                "v0.1/adapter-node/"
              ],
              "extensions": [
                ".md",
                ".json",
                ".ts",
                ".yaml",
                ".yml"
              ]
            },
            {
              "fileNames": [
                "Makefile",
                "pyproject.toml",
                "uv.lock",
                "compose.yaml",
                ".env.example",
                ".gitignore",
                "package.json",
                "package-lock.json",
                "buf.yaml",
                "buf.gen.connect-local.yaml",
                "buf.gen.ts.yaml"
              ],
              "segments": [
                "v0.1"
              ]
            }
          ],
          "commands": [
            {
              "label": "tfo prototype python syntax",
              "command": "uv run --no-sync python -m compileall -q src scripts tests",
              "cwd": "v0.1",
              "timeoutMs": 180000,
              "maxBuffer": 4194304,
              "id": "tfo-prototype-python-syntax",
              "classes": [
                "quality",
                "targeted"
              ]
            },
            {
              "label": "tfo prototype adapter config syntax",
              "command": "node -e \"const fs=require('fs'); for (const f of ['package.json','tsconfig.json']) JSON.parse(fs.readFileSync(f,'utf8')); console.log('adapter config ok')\"",
              "cwd": "v0.1/adapter-node",
              "timeoutMs": 120000,
              "maxBuffer": 4194304,
              "id": "tfo-prototype-adapter-config-syntax",
              "classes": [
                "targeted",
                "quality"
              ]
            }
          ]
        }
      }
    },
